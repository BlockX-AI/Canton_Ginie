# Ginie Backend Environment Configuration
# Copy this file to .env.ginie and fill in your values

# --- LLM Provider ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/ginie
REDIS_URL=redis://localhost:6379/0

# --- Canton Sandbox PostgreSQL (separate from Ginie app DB) ---
CANTON_DB_HOST=localhost
CANTON_DB_PORT=5432
CANTON_DB_NAME=canton_sandbox
CANTON_DB_USER=postgres
CANTON_DB_PASSWORD=password

# --- Canton URLs ---
CANTON_SANDBOX_URL=http://localhost:7575
CANTON_DEVNET_URL=
CANTON_MAINNET_URL=
CANTON_ENVIRONMENT=sandbox

# --- Canton JWT Authentication (REQUIRED for production) ---
# Set this to the path to your private key file (e.g., "keys/canton_private.pem")
# or the PEM string directly. If unset, falls back to unsigned wildcard JWT (sandbox only).
CANTON_JWT_PRIVATE_KEY=
CANTON_JWT_ALGORITHM=RS256

# --- Daml SDK ---
DAML_SDK_PATH=~/.daml/bin/daml
DAML_SDK_VERSION=2.10.4
DAR_OUTPUT_DIR=/tmp/ginie_jobs

# --- JWT (for Ginie API authentication) ---
JWT_SECRET=generate-a-strong-random-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=7

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,https://canton.ginie.xyz,https://*.vercel.app

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Logging ---
LOG_LEVEL=INFO

# --- Pipeline Tuning ---
MAX_FIX_ATTEMPTS=3
LLM_TEMPERATURE=0.1
LLM_REQUEST_TIMEOUT_SECONDS=90.0
AUDIT_MAX_SECONDS=240.0

# --- Vector DB ---
CHROMA_PERSIST_DIR=./rag/chroma_db
